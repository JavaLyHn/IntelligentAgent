<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.intelligentagent.mapper.WorkflowConfigMapper">

    <select id="selectActiveOrderByUpdatedAtDesc" resultType="com.intelligentagent.entity.WorkflowConfig">
        SELECT * FROM workflow_configs
        WHERE active = 1
        ORDER BY updated_at DESC
    </select>

    <select id="selectPageActive" resultType="com.intelligentagent.entity.WorkflowConfig">
        SELECT * FROM workflow_configs
        WHERE active = 1
        <if test="name != null and name != ''">
            AND name LIKE CONCAT('%', #{name}, '%')
        </if>
        ORDER BY updated_at DESC
    </select>

</mapper>
